# ====================================
# EMBEDDING CONFIGURATION
# ====================================

# Embedding provider: "local" (default) or "openai"
EMBEDDING_PROVIDER=local

# Local embedding model (used when EMBEDDING_PROVIDER=local)
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=auto  # or "cuda" for GPU, "auto" for automatic detection
EMBEDDING_CACHE_FOLDER=./models/embeddings

# OpenAI embeddings (used when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # or text-embedding-3-large, text-embedding-ada-002
OPENAI_BASE_URL=  # Optional: custom OpenAI-compatible endpoint

# ====================================
# VECTOR DATABASE CONFIGURATION
# ====================================

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=course_docs_clean

# PostgreSQL + pgvector
PGVECTOR_HOST=pgvector_db
PGVECTOR_PORT=5432
PGVECTOR_USER=pguser
PGVECTOR_PASSWORD=pgpass
PGVECTOR_DATABASE=vectordb

# ====================================
# LLM CONFIGURATION
# ====================================

# Ollama (local LLM)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=phi3:mini

# ====================================
# APPLICATION SETTINGS
# ====================================

DEBUG=false
LOG_LEVEL=INFO
API_PORT=8080

# ====================================
# OFFLINE MODE
# ====================================

# Set to "1" to force fully offline operation
# This prevents any internet requests for model downloads
TRANSFORMERS_OFFLINE=0
HF_DATASETS_OFFLINE=0

# If you want to use pre-downloaded models only
HF_HOME=./models/huggingface  # Local cache for HuggingFace models
